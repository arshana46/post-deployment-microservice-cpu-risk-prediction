      <aliases enabled='yes' />
      <column caption='Latest Risk Score Percent' datatype='real' name='[Calculation_0763370736660480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [datetime] = { FIXED [microservice] : MAX([datetime]) } THEN [risk_score_percent] END' />
      </column>
      <column caption='Risk Score Percent2' datatype='real' name='[Calculation_0763370739929089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([risk_score_percent])' />
      </column>
      <column caption='Risk level' datatype='string' name='[Calculation_1138579136434176]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([risk_score_percent]) &lt; 30 THEN &quot;SAFE&quot;&#13;&#10;ELSEIF AVG([risk_score_percent]) &lt; 60 THEN &quot;WARNING&quot;&#13;&#10;ELSE &quot;CRITICAL&quot;&#13;&#10;END' />
      </column>
      <column caption='Risk Bucket' datatype='string' name='[Calculation_1138579183247361]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [risk_score_percent] &lt; 30 THEN &quot;0–30 (Safe)&quot;&#13;&#10;ELSEIF [risk_score_percent] &lt; 60 THEN &quot;30–60 (Warning)&quot;&#13;&#10;ELSE &quot;60–100 (High Risk)&quot;&#13;&#10;END' />
      </column>
      <column aggregation='None' caption='Risk Score Percent (bin)' datatype='integer' name='[Risk Score Percent (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='1' formula='[risk_score_percent]' peg='0' size='30' />
      </column>
